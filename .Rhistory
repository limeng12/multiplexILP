library(stringr)
gen_cons<-function(n=10, m=50){
x <- sample(1:(n-2), m, replace = TRUE)
y <- sapply(x, function(xi) sample((xi+1):n, 1))
cons<-str_c("X", x," + X",  y," <= 1")
unique(cons)
}
old_cons<-gen_cons(10,100)
new_cons <- convert_constraints(old_cons)
