mat<-noise
# 2. 使用更适合二进制数据的方法：二值矩阵分解(BMF)
# 使用NMF包，设置二进制模式
library(NMF)
set.seed(123)
# 2.1 非负矩阵分解（调整参数）
rank_est <- 3  # 假设3个聚类
nmf_result <- nmf(mat, rank = rank_est, method = "lee", seed = 123)
# 获取聚类结果
nmf_clusters <- predict(nmf_result)
# 添加一些噪声
noise <- matrix(rbinom(n*p, 1, 0.1), n, p)
mat<-noise
# 2. 使用更适合二进制数据的方法：二值矩阵分解(BMF)
# 使用NMF包，设置二进制模式
library(NMF)
set.seed(123)
# 2.1 非负矩阵分解（调整参数）
rank_est <- 3  # 假设3个聚类
nmf_result <- nmf(mat, rank = rank_est, method = "lee", seed = 123)
# 获取聚类结果
nmf_clusters <- predict(nmf_result)
mat
# 添加一些噪声
noise <- matrix(rbinom(n*p, 1, 0.5), n, p)
mat <- (mat + noise) %% 2
mat<-noise
# 2. 使用更适合二进制数据的方法：二值矩阵分解(BMF)
# 使用NMF包，设置二进制模式
library(NMF)
set.seed(123)
# 2.1 非负矩阵分解（调整参数）
rank_est <- 3  # 假设3个聚类
nmf_result <- nmf(mat, rank = rank_est, method = "lee", seed = 123)
# 获取聚类结果
nmf_clusters <- predict(nmf_result)
# 2.2 按NMF结果排序矩阵
row_order_nmf <- order(nmf_clusters)
col_silhouette <- silhouette(t(mat), dist(t(mat), method = "binary"))
col_order_nmf <- order(cutree(hclust(dist(t(mat), method = "binary")), 3))
col_order_nmf <- order(cutree(hclust(dist(t(mat), method = "binary")), 3))
# 可视化NMF聚类结果
sorted_nmf <- mat[row_order_nmf, col_order_nmf]
col_order_nmf
mat[row_order_nmf,]
row_order_nmf
# 可视化NMF聚类结果
sorted_nmf <- mat[row_order_nmf, col_order_nmf]
# 3. 使用谱聚类（适合复杂结构）
library(kernlab)
# 3.1 构建相似度矩阵
jaccard_sim <- 1 - as.matrix(dist(mat, method = "binary"))
spectral <- specc(jaccard_sim, centers = 3)
# 按谱聚类结果排序
row_order_spec <- order(spectral)
sorted_spec <- mat[row_order_spec, ]
# 可视化
pheatmap(sorted_spec,
color = c("white", "black"),
cluster_rows = FALSE,
cluster_cols = TRUE,  # 列仍然聚类
clustering_distance_cols = "binary",
main = "Spectral Clustering Result")
# 4. 双向聚类（同时发现行和列的簇）
library(biclust)
# 4.1 CC算法（适合0-1数据）
bc <- biclust(mat, method = BCCC(), delta = 1.0, alpha = 1.0)
# 提取第一个双向聚类块
cluster_mat <- mat[bc@RowxNumber[,1], bc@NumberxCol[1,]]
pheatmap(cluster_mat,
color = c("white", "black"),
cluster_rows = FALSE,
cluster_cols = FALSE,
main = "Biclustering Block")
# 尝试改进0-1矩阵聚类效果的方案
