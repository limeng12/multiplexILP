library(factoextra)
library(NMF)
# 1. 数据准备（增加区分度）
set.seed(42)
n <- 150
p <- 250
# 创建更有区分度的矩阵（有更明显的块结构）
mat <- matrix(0, n, p)
mat[1:5, 1:8] <- 1
mat[6:10, 9:16] <- 1
mat[11:15, 17:25] <- 1
# 添加一些噪声
noise <- matrix(rbinom(n*p, 1, 0.5), n, p)
mat <- (mat + noise) %% 2
mat<-noise
# 2. 使用更适合二进制数据的方法：二值矩阵分解(BMF)
# 使用NMF包，设置二进制模式
library(NMF)
set.seed(123)
# 2.1 非负矩阵分解（调整参数）
rank_est <- 3  # 假设3个聚类
nmf_result <- nmf(mat, rank = rank_est, method = "lee", seed = 123)
# 4.1 CC算法（适合0-1数据）
bc <- biclust(mat, method = BCCC(), delta = 1.0, alpha = 1.0)
# 提取第一个双向聚类块
cluster_mat <- mat[bc@RowxNumber[,1], bc@NumberxCol[1,]]
pheatmap(cluster_mat,
